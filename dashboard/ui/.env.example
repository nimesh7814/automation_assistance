# Copy this file to ui/.env and fill in your key. Used both when running the
# UI directly (streamlit run app.py, via python-dotenv) and via Docker Compose
# (env_file). Never commit the real ui/.env file.

# Required for the Assistant tab. Get a free-tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model used by the Assistant tab.
# GEMINI_MODEL=gemini-2.5-flash
